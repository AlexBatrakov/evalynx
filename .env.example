# Core application settings
EVALYNX_APP_NAME=Evalynx
EVALYNX_ENV=development
EVALYNX_DEBUG=false
EVALYNX_API_PREFIX=

# Runtime infrastructure
EVALYNX_DATABASE_URL=postgresql+psycopg://evalynx:evalynx@localhost:5432/evalynx
EVALYNX_REDIS_URL=redis://localhost:6379/0
EVALYNX_RQ_QUEUE_NAME=evalynx-runs
EVALYNX_RQ_JOB_TIMEOUT=600

# Optional: only required for the host-based real runner path.
# The Docker Compose reviewer demo works without these values.
EVALYNX_SOLO_WARGAME_REPO_PATH=
EVALYNX_SOLO_WARGAME_PYTHON_COMMAND=python

# Shared artifact output directory for both stub and real runner flows.
EVALYNX_ARTIFACT_ROOT=./artifacts

# Docker Compose PostgreSQL defaults
POSTGRES_DB=evalynx
POSTGRES_USER=evalynx
POSTGRES_PASSWORD=evalynx
